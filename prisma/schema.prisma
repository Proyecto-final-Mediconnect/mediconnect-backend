generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum user_role {
  PACIENTE
  PROFESIONAL
  MODERADOR
}

/// Estado de validación de un profesional. Al registrarse queda en
/// PENDIENTE_VALIDACION_MATRICULA; el equipo valida la matrícula manualmente
/// en el MVP (ENG-43).
enum professional_status {
  PENDIENTE_VALIDACION_MATRICULA
  VALIDADO
  RECHAZADO
  SUSPENDIDO
}

/// Perfil base 1:1 con auth.users de Supabase. Portador del rol.
/// La fila se crea automáticamente vía trigger on_auth_user_created al
/// registrarse el usuario en Supabase Auth (ver migración ep01_*).
model Profile {
  id          String    @id @db.Uuid
  email       String    @unique
  role        user_role
  mfa_enabled Boolean   @default(false)
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  updated_at   DateTime      @default(now()) @db.Timestamptz(6)
  patient      Patient?
  professional Professional?

  @@map("profiles")
}

/// Perfil de paciente 1:1 con Profile (role = PACIENTE).
/// Los datos personales se completan en ENG-47, no en el registro.
model Patient {
  profile_id String    @id @db.Uuid
  first_name String
  last_name  String
  birth_date DateTime? @db.Date
  dni        String?   @unique @db.VarChar(15)
  phone      String?
  address    String?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  profile    Profile   @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@map("patients")
}

/// Perfil de profesional 1:1 con Profile (role = PROFESIONAL).
/// Se crea al registrarse (ENG-43) con status PENDIENTE_VALIDACION_MATRICULA.
/// La especialidad se asigna desde el catálogo (professional_specialties) en la
/// validación manual de matrícula; en el registro se captura en metadata.
model Professional {
  profile_id             String              @id @db.Uuid
  first_name             String
  last_name              String
  license_number         String              @db.VarChar(30)
  status                 professional_status @default(PENDIENTE_VALIDACION_MATRICULA)
  bio                    String?             @db.VarChar(500)
  photo_url              String?
  consultation_price     Decimal?            @db.Decimal(10, 2)
  currency               String?             @db.Char(3)
  mercadopago_account_id String?
  created_at             DateTime            @default(now()) @db.Timestamptz(6)
  updated_at             DateTime            @default(now()) @db.Timestamptz(6)
  profile                Profile             @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@map("professionals")
}
