generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum user_role {
  PACIENTE
  PROFESIONAL
  MODERADOR
}

/// Perfil base 1:1 con auth.users de Supabase. Portador del rol.
/// La fila se crea automáticamente vía trigger on_auth_user_created al
/// registrarse el usuario en Supabase Auth (ver migración ep01_*).
model Profile {
  id          String    @id @db.Uuid
  email       String    @unique
  role        user_role
  mfa_enabled Boolean   @default(false)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @db.Timestamptz(6)
  patient     Patient?

  @@map("profiles")
}

/// Perfil de paciente 1:1 con Profile (role = PACIENTE).
/// Los datos personales se completan en ENG-47, no en el registro.
model Patient {
  profile_id String    @id @db.Uuid
  first_name String
  last_name  String
  birth_date DateTime? @db.Date
  dni        String?   @unique @db.VarChar(15)
  phone      String?
  address    String?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  profile    Profile   @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@map("patients")
}
