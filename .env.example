# Base de datos (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Supabase
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Autenticación (Supabase Auth)
# No se usa secreto de JWT: los tokens se firman con claves asimétricas (ES256)
# y se verifican en el backend contra el JWKS de Supabase, derivado de SUPABASE_URL
# (https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json). Ver ENG-40.

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""

# Daily.co (videoconsulta)
DAILY_API_KEY=""

# OpenAI Whisper (transcripción)
OPENAI_API_KEY=""

# Google Gemini (resumen clínico)
GEMINI_API_KEY=""

# App
PORT="3000"
NODE_ENV="development"