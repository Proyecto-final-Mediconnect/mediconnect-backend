# ---------------------------------------------------------------------------
# Base de datos
# ---------------------------------------------------------------------------
# DESARROLLO LOCAL: Postgres del docker-compose. Este es el valor por defecto.
#   - Dentro del devcontainer, el host es "db" (nombre del servicio).
#   - Si corrés el backend en tu host (no en el devcontainer), usá "localhost".
DATABASE_URL="postgresql://postgres:postgres@db:5432/mediconnect?schema=public"
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mediconnect?schema=public"
#
# PRODUCCIÓN: connection string del proyecto Supabase (NO se versiona).

# ---------------------------------------------------------------------------
# Supabase (SOLO producción / staging; en local no se usa)
# ---------------------------------------------------------------------------
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Autenticación (Supabase Auth)
# No se usa secreto de JWT: los tokens se firman con claves asimétricas (ES256)
# y se verifican en el backend contra el JWKS de Supabase, derivado de SUPABASE_URL
# (https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json). Ver ENG-40.

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""

# Daily.co (videoconsulta)
DAILY_API_KEY=""

# OpenAI Whisper (transcripción)
OPENAI_API_KEY=""

# Google Gemini (resumen clínico)
GEMINI_API_KEY=""

# App
PORT="3000"
NODE_ENV="development"
