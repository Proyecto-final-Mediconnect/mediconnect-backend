# Base de datos (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Base de datos de test (PostgreSQL 15 en Docker, ver docker-compose.yml).
# `pnpm run test:integration` ya usa estos valores por defecto internamente;
# solo hace falta declararlos acá si querés sobreescribir puerto/usuario/db.
# DATABASE_URL de test: postgresql://mediconnect:mediconnect@localhost:5433/mediconnect_test?schema=public
POSTGRES_TEST_USER="mediconnect"
POSTGRES_TEST_PASSWORD="mediconnect"
POSTGRES_TEST_DB="mediconnect_test"
POSTGRES_TEST_PORT="5433"

# Supabase
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# JWT
JWT_SECRET=""
JWT_EXPIRATION="15m"

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""

# Daily.co (videoconsulta)
DAILY_API_KEY=""

# OpenAI Whisper (transcripción)
OPENAI_API_KEY=""

# Google Gemini (resumen clínico)
GEMINI_API_KEY=""

# App
PORT="3000"
NODE_ENV="development"